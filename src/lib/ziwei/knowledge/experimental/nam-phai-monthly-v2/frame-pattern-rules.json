    {
      "id": "FOCUS_VOID_MAJOR_BORROW_OPPOSITE",
      "name": "Vô chính diệu borrows opposite palace",
      "scope": "focus-palace",
      "when": {
        "focusHasNoMajorStar": true,
        "oppositeHasMajorStar": true
      },
      "effects": [
        {
          "operation": "borrowMajorStarSignals",
          "fromRole": "xung",
          "factor": 0.65
        },
        {
          "axis": "stability",
          "delta": -8
        },
        {
          "axis": "activation",
          "delta": 5
        }
      ],
      "notes": "Do not add a standalone bad score merely because the focus palace is empty."
    },
    {
      "id": "SAME_STAR_LOC_KY_CROSS_LAYER",
      "name": "Same star receives Lộc and Kỵ across layers",
      "scope": "same-star",
      "when": {
        "hasTransformsAcrossLayers": [
          "Lộc",
          "Kỵ"
        ]
      },
      "effects": [
        {
          "axis": "activation",
          "delta": 16
        },
        {
          "axis": "conflict",
          "delta": 18
        },
        {
          "axis": "risk",
          "delta": 6
        }
      ]
    },
    {
      "id": "SAME_STAR_QUYEN_KY_CROSS_LAYER",
