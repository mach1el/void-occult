    {
      "id": "MONTH_REACTIVATES_MAJOR_FORTUNE_PALACE",
      "name": "Monthly focus equals active major-fortune palace",
      "scope": "monthly-context",
      "when": {
        "monthlyFocusEqualsActiveMajorFortunePalace": true
      },
      "effects": [
        {
          "axis": "activation",
          "delta": 20
        },
        {
          "operation": "applyLinkedSignalFactors",
          "benefitFactor": 1.1,
          "riskFactor": 1.15
        }
      ]
    }
  ]
