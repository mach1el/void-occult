      },
      "effects": [
        {
          "axis": "activation",
          "delta": 18
        },
        {
          "axis": "conflict",
          "delta": 15
        },
        {
          "axis": "risk",
          "delta": 8
        }
      ]
    },
    {
      "id": "SAME_STAR_LOC_QUYEN_CROSS_LAYER",
      "name": "Same star receives Lộc and Quyền across layers",
