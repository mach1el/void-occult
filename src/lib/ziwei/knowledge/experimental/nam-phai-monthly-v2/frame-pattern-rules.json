{
  "version": "0.1.0",
  "status": "experimental",
  "rules": [
    {
      "id": "FRAME_SAT_PHA_THAM",
      "name": "Sát Phá Tham frame",
      "scope": "san-fang-si-zheng",
      "requiresAllStars": [
        "Thất Sát",
        "Phá Quân",
        "Tham Lang"
      ],
      "effects": [
        {
          "axis": "activation",
          "delta": 18
        }
      ],
      "conditionalEffects": [
        {
          "when": {
            "brightCountAtLeast": 2,
            "allowedBrightness": [
              "Miếu",
              "Vượng",
              "Đắc"
            ],
            "hasAnyTransform": [
              "Lộc",
              "Quyền",
              "Khoa"
            ]
          },
          "effects": [
            {
              "axis": "benefit",
              "delta": 10
            }
          ]
        },
        {
          "when": {
            "afflictedMajorCountAtLeast": 2,
            "afflictions": [
              "Hãm",
              "Kỵ",
              "lục-sát-same-palace"
            ]
          },
          "effects": [
            {
              "axis": "risk",
              "delta": 12
            },
            {
              "axis": "conflict",
              "delta": 8
            }
          ]
        }
      ],
      "notes": "Never classify Sát Phá Tham as purely auspicious or purely inauspicious. Its primary semantic is change/activation."
    },
    {
