  "axisLabels": {
    "support": [
      "low",
      "medium",
      "high"
    ],
    "pressure": [
      "low",
      "medium",
      "high"
    ],
    "stability": [
      "low",
      "medium",
      "high"
    ],
    "activation": [
      "low",
      "medium",
      "high"
    ]
  },
  "palaceLabelSchema": {
    "palaceName": "string",
    "support": "low|medium|high|null",
    "pressure": "low|medium|high|null",
    "stability": "low|medium|high|null",
    "activation": "low|medium|high|null",
    "notes": "string|null",
    "reviewer": "string|null",
    "reviewStatus": "unreviewed|reviewed|disputed"
  },
  "pairwiseComparisonSchema": {
    "leftPalace": "string",
    "axis": "support|pressure|stability|activation",
    "relation": "greater|less|similar",
    "rightPalace": "string",
    "notes": "string|null"
  }
