  "annualDomainFrame": {
    "focusOffset": 0,
    "oppositeOffset": 6,
    "trineOffsets": [
      4,
      8
    ],
    "modulo": 12
  },
  "monthlyActivationFrame": {
    "focusOffset": 0,
    "oppositeOffset": 6,
    "trineOffsets": [
      4,
      8
    ],
