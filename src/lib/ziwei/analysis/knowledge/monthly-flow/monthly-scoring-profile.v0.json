{
  "schemaVersion": "0.1.0",
  "profileId": "monthly-flow-scoring-experimental-v0",
  "status": "experimental",
  "requiresCalibration": true,
  "axes": [
    "support",
    "pressure",
    "stability",
    "activation"
  ],
  "output": {
    "scoreMin": 0,
    "scoreMax": 100,
    "scorePrecision": 1,
    "bands": [
      {
        "minInclusive": 0,
        "maxExclusive": 50,
        "id": "guarded",
        "labelVi": "Cẩn trọng"
      },
      {
        "minInclusive": 50,
        "maxExclusive": 60,
        "id": "balanced",
        "labelVi": "Cân bằng"
      },
      {
        "minInclusive": 60,
        "maxExclusive": 75,
        "id": "supportive",
        "labelVi": "Thuận lợi"
      },
      {
        "minInclusive": 75,
        "maxInclusive": 100,
        "id": "strong",
        "labelVi": "Mạnh"
      }
    ]
  },
  "frameRoleWeights": {
    "annualDomain": {
      "focus": 1.0,
      "opposite": 0.75,
      "trine": 0.65
    },
    "monthlyActivation": {
      "focus": 1.0,
      "opposite": 0.7,
      "trine": 0.6
    }
  },
  "evidenceLayerWeights": {
    "monthly-focus-star": 1.0,
    "monthly-transformation": 1.0,
    "annual-star-context": 0.45,
    "annual-transformation-context": 0.55,
    "major-transformation-context": 0.25,
    "major-active-palace-context": 0.2,
    "structural-activation": 1.0,
    "interaction": 0.35
  },
  "confidenceWeights": {
    "approved": 1.0,
    "experimental": 0.75
  },
  "diminishingReturns": {
    "formula": "inverse_square_root_rank",
    "rankBase": 1,
    "expression": "1 / sqrt(rank)"
  },
  "normalization": {
    "supportScale": 3.0,
    "pressureScale": 3.0,
    "stabilityScale": 3.0,
    "activationScale": 2.5,
    "stabilityCoefficient": 0.3,
    "activationGateFloor": 0.2,
    "activationGateRange": 0.8,
    "scoreAmplitude": 42.0,
    "scoreDivisor": 1.2,
    "neutralScore": 50.0
  },
  "formulaSpec": {
    "supportNorm": "1 - exp(-supportRaw / supportScale)",
    "pressureNorm": "1 - exp(-pressureRaw / pressureScale)",
    "stabilityNorm": "tanh(stabilityRaw / stabilityScale)",
    "activationNorm": "1 - exp(-activationRaw / activationScale)",
    "netQuality": "supportNorm - pressureNorm + stabilityCoefficient * stabilityNorm",
    "activationGate": "activationGateFloor + activationGateRange * activationNorm",
    "score": "clamp(neutralScore + scoreAmplitude * tanh((netQuality * activationGate) / scoreDivisor), 0, 100)",
    "intensity": "round(100 * activationNorm)",
    "conflict": "round(100 * min(supportNorm, pressureNorm) * activationNorm)"
  },
  "dedup": {
    "identityFields": [
      "annualYear",
      "monthKey",
      "school",
      "domain",
      "category",
      "physicalFactId",
      "ruleId",
      "targetPalaceIndex"
    ],
    "duplicateAcrossAnchorsBehavior": "keep_highest_base_weight",
    "sameNatalStarAcrossTemporalContextsBehavior": "count_as_monthly-focus-star_once",
    "transformationsAreDistinctPhysicalFacts": true,
    "semanticAnnotationsAreNumeric": false
  }
}
