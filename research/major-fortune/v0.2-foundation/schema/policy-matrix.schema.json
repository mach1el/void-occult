{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Major Fortune V0.2 Policy Document",
  "type": "object",
  "required": [
    "schemaVersion",
    "policyId",
    "claimIds",
    "sourceIds"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "policyId": {
      "type": "string"
    },
    "pillarId": {
      "type": "string"
    },
    "claimIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sourceIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
