{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "families"
  ],
  "properties": {
    "families": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "familyId",
          "eligibility",
          "existence",
          "scope",
          "polarity",
          "frame",
          "evidence"
        ],
        "properties": {
          "evidence": {
            "type": "object",
            "required": [
              "existenceClaimIds",
              "scopeClaimIds",
              "polarityClaimIds",
              "frameClaimIds",
              "stackingClaimIds"
            ]
          },
          "stackingContract": {
            "type": "string"
          }
        }
      }
    }
  }
}
