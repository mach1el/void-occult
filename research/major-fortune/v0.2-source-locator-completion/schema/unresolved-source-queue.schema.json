{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schemaVersion",
    "queueId",
    "items"
  ],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "queueId",
          "priority",
          "neededTopics",
          "blocker",
          "ownerAction"
        ],
        "properties": {
          "sourceId": {
            "type": [
              "string",
              "null"
            ]
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
